# Currency Symbol
NEXT_PUBLIC_CURRENCY_SYMBOL = '$'

# JWT Secret (must match backend JWT_SECRET_KEY)
JWT_SECRET_KEY = 'jwt-secret-string-change-in-production'

# Backend URL (for Docker deployment with Nginx routing)
# For local development: http://127.0.0.1:5000
# For Docker production: http://backend:5000
FLASK_BACKEND_URL = 'http://backend:5000'

# Frontend API URL (for Docker deployment with Nginx routing)
# For local development: http://localhost:5000
# For Docker production: /api (proxied by Nginx)
NEXT_PUBLIC_API_URL = '/api'
